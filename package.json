{
  "name": "optiflow",
  "version": "1.0.0",
  "description": "Tablet-optimized Kanban board for optician shops",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @optiflow/web dev",
    "dev:api": "pnpm --filter @optiflow/api dev",
    "build": "pnpm --filter @optiflow/web build && pnpm --filter @optiflow/api build",
    "build:web": "pnpm --filter @optiflow/web build",
    "build:api": "pnpm --filter @optiflow/api build",
    "start": "pnpm start:web",
    "start:web": "pnpm --filter @optiflow/web start",
    "start:api": "pnpm --filter @optiflow/api start",
    "lint": "pnpm --filter @optiflow/web lint && pnpm --filter @optiflow/api lint",
    "lint:web": "pnpm --filter @optiflow/web lint",
    "lint:api": "pnpm --filter @optiflow/api lint",
    "test": "pnpm --filter @optiflow/web test && pnpm --filter @optiflow/api test",
    "test:web": "pnpm --filter @optiflow/web test",
    "test:api": "pnpm --filter @optiflow/api test",
    "test:ui": "pnpm --filter @optiflow/web test:ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsomlette/optiflow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rsomlette/optiflow/issues"
  },
  "homepage": "https://github.com/rsomlette/optiflow#readme",
  "dependencies": {},
  "devDependencies": {}
}
